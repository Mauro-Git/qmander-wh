# ── Webhook ──────────────────────────────────────────────
# Genera con: openssl rand -hex 32
WEBHOOK_SECRET=
PORT=3000

# ── Riesgo ───────────────────────────────────────────────
ALLOWED_SYMBOLS=EURUSD,XAUUSD
MAX_LOTS=0.01
# Stop loss por defecto en pips si la alerta no lo trae (0 = obligatorio en payload)
DEFAULT_SL_PIPS=0
MAX_DAILY_REQUESTS=1500

# ── cTrader Open API (JSON sobre WebSocket, puerto 5036) ─
# demo.ctraderapi.com para cuenta demo, live.ctraderapi.com para real
CTRADER_HOST=demo.ctraderapi.com
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
CTRADER_ACCESS_TOKEN=
CTRADER_ACCOUNT_ID=

# Mapeo opcional ticker TradingView → símbolo cTrader (JSON)
# SYMBOL_MAP={"US500":"US500.cash"}
